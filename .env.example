# ============================================================
#  AURELIA — environment variables
#  Copy to `.env.local` for local dev, or `.env` on the VPS.
# ============================================================

# ── THE ONLY SECRET YOU MUST ADD ────────────────────────────
# Google AI Studio key, used ONLY on the server to mint short-lived
# ephemeral tokens for the voice agent. Never sent to the browser.
# Use a legacy "AIza..." key (the newer "AQ.*" format is rejected by
# authTokens.create). Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Optional (safe defaults already baked in) ───────────────
# Gemini Live model the browser connects with (public, not a secret).
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Canonical site URL for metadata / absolute links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Production runtime (set by pm2 / systemd on the VPS) ─────
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
